{
  "name": "dextr-deepagent-poc",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:client && nest build",
    "build:client": "cd app-client && npm run build",
    "dev": "concurrently -n server,client,ready \"npm run start:dev\" \"npm run dev:client\" \"npm run dev:ready\"",
    "dev:client": "cd app-client && npm run dev",
    "dev:ready": "wait-on -t 60000 tcp:localhost:3000 tcp:localhost:5173 && node scripts/print-ready.js",
    "format": "prettier --write \"app-client/**/*.{ts,tsx}\" \"app-server/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/app-server/src/main",
    "lint": "eslint \"{src,app-client,app-server,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./jest-e2e.json",
    "test:find": "jest --config ./jest-find.json",
    "testt": "jest --config ./jest-e2e.json",
    "migrate": "knex migrate:latest --knexfile knexfile.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.0",
    "@langchain/openai": "^1.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.4",
    "deepagents": "^1.7.0",
    "dotenv": "^16.4.0",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.36.0"
  },
  "overrides": {
    "form-data": ">=2.5.4",
    "ajv": ">=8.18.0",
    "minimatch": ">=10.2.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "app-server/src",
    "testRegex": ".*\\.test\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.{ts,js}"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
